<!DOCTYPE html>
<html lang="en" xmlns="http://www.w3.org/1999/xhtml">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <title>Verify Your Account – DSAGC LMS</title>
  <style>
    body { margin: 0; padding: 0; background-color: #f0f4f8; font-family: Arial, sans-serif; }
    table { border-collapse: collapse; mso-table-lspace: 0pt; mso-table-rspace: 0pt; }
    img { border: 0; display: block; }
    a { color: #1565a8; }

    .body-p {
      font-family: Arial, sans-serif;
      font-size: 15px;
      line-height: 1.75;
      color: #4a5568;
      margin: 0 0 14px 0;
      padding: 0;
    }
    .greeting {
      font-family: Georgia, 'Times New Roman', serif;
      font-size: 20px;
      font-weight: 600;
      color: #0b3d6e;
      margin: 0 0 14px 0;
    }
    .cta-btn {
      display: inline-block;
      background-color: #1565a8;
      color: #ffffff !important;
      text-decoration: none;
      font-family: Arial, sans-serif;
      font-size: 15px;
      font-weight: bold;
      letter-spacing: 0.04em;
      padding: 16px 44px;
      border-radius: 10px;
    }
    .fallback-url {
      word-break: break-all;
      font-size: 12px;
      color: #1565a8;
      font-family: 'Courier New', monospace;
    }
    @media screen and (max-width: 640px) {
      .outer-wrap { padding: 12px !important; }
      .main-table { border-radius: 12px !important; }
      .hdr-cell { padding: 28px 24px 24px !important; }
      .body-cell { padding: 24px 24px 0 !important; }
      .cta-cell { padding: 20px 24px !important; }
      .expiry-cell { padding: 12px 18px !important; margin: 0 24px !important; }
      .fallback-cell { padding: 20px 24px 0 !important; }
      .security-cell { padding: 0 24px !important; }
      .footer-cell { padding: 24px !important; }
      .hdr-title { font-size: 24px !important; }
    }
  </style>
</head>
<body style="margin:0;padding:0;background-color:#f0f4f8;">

<!-- outer wrapper -->
<table width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color:#f0f4f8;">
  <tr>
    <td align="center" class="outer-wrap" style="padding:32px 16px;">

      <!-- main card -->
      <table class="main-table" width="620" cellpadding="0" cellspacing="0" border="0"
             style="max-width:620px;width:100%;background:#ffffff;border-radius:16px;overflow:hidden;border:1px solid #e2ecf6;">

        <!-- ══ HEADER ══ -->
        <tr>
          <td class="hdr-cell" style="background-color:#1263a3;padding:40px 48px 36px;">

            <!--
              Gmail-safe decorative bubbles: use actual table cells with
              background-color + border-radius instead of ::before/::after.
              We layer them using a nested table that positions content over a coloured bg.
            -->

            <!-- Bubble layer table (fakes the two decorative circles) -->
            <table width="100%" cellpadding="0" cellspacing="0" border="0"
                   style="background:linear-gradient(135deg,#0b3d6e 0%,#1565a8 60%,#1e82d4 100%);
                          border-radius:12px;margin:-8px -16px;padding:8px 16px;">
              <tr>
                <td style="padding:0;">

                  <!-- top-right bubble -->
                  <table align="right" cellpadding="0" cellspacing="0" border="0"
                         style="float:right;margin:-32px -32px 0 0;">
                    <tr>
                      <td width="180" height="180"
                          style="width:180px;height:180px;border-radius:50%;
                                 background-color:rgba(255,255,255,0.07);
                                 font-size:0;line-height:0;">&nbsp;</td>
                    </tr>
                  </table>

                  <!-- bottom-left bubble -->
                  <table align="left" cellpadding="0" cellspacing="0" border="0"
                         style="float:left;margin:40px 0 -80px -48px;">
                    <tr>
                      <td width="240" height="240"
                          style="width:240px;height:240px;border-radius:50%;
                                 background-color:rgba(255,255,255,0.05);
                                 font-size:0;line-height:0;">&nbsp;</td>
                    </tr>
                  </table>

                  <!-- ACTUAL HEADER CONTENT on top of bubbles -->
                  <table width="100%" cellpadding="0" cellspacing="0" border="0"
                         style="position:relative;z-index:2;">

                    <!-- Logo row: table-based, Gmail safe -->
                    <tr>
                      <td style="padding-bottom:24px;">
                        <table cellpadding="0" cellspacing="0" border="0">
                          <tr>
                            <!-- DS badge: td with fixed size + text-align center -->
                            <td width="52" height="52" align="center" valign="middle"
                                style="width:52px;height:52px;min-width:52px;
                                       background-color:rgba(255,255,255,0.15);
                                       border:1px solid rgba(255,255,255,0.35);
                                       border-radius:12px;
                                       font-family:Georgia,'Times New Roman',serif;
                                       font-size:17px;font-weight:700;
                                       color:#ffffff;text-align:center;
                                       vertical-align:middle;
                                       line-height:52px;">
                              DS
                            </td>
                            <td width="14" style="width:14px;">&nbsp;</td>
                            <td valign="middle" style="vertical-align:middle;">
                              <div style="font-family:Arial,sans-serif;font-size:10px;
                                          font-weight:600;letter-spacing:0.18em;
                                          text-transform:uppercase;color:rgba(255,255,255,0.65);
                                          margin-bottom:3px;">
                                DSAGC &middot; LMS Portal
                              </div>
                              <div style="font-family:Georgia,'Times New Roman',serif;
                                          font-size:15px;font-weight:600;color:#ffffff;">
                                Debidwar Sujat Ali Govt. College
                              </div>
                            </td>
                          </tr>
                        </table>
                      </td>
                    </tr>

                    <!-- Divider line -->
                    <tr>
                      <td style="padding-bottom:18px;">
                        <table width="48" cellpadding="0" cellspacing="0" border="0">
                          <tr>
                            <td height="2" style="height:2px;background-color:rgba(255,255,255,0.3);
                                                   border-radius:2px;font-size:0;line-height:0;">&nbsp;</td>
                          </tr>
                        </table>
                      </td>
                    </tr>

                    <!-- Label + title -->
                    <tr>
                      <td>
                        <div style="font-family:Arial,sans-serif;font-size:10px;font-weight:600;
                                    letter-spacing:0.2em;text-transform:uppercase;
                                    color:rgba(255,255,255,0.6);margin-bottom:8px;">
                          Account Activation
                        </div>
                        <div class="hdr-title"
                             style="font-family:Georgia,'Times New Roman',serif;
                                    font-size:30px;font-weight:700;color:#ffffff;line-height:1.25;">
                          Verify Your<br/>Email Address
                        </div>
                      </td>
                    </tr>

                  </table><!-- /header content -->
                </td>
              </tr>
            </table><!-- /bubble layer -->

          </td>
        </tr>

        <!-- ══ SHIELD ICON ══ -->
        <tr>
          <td align="center" style="padding:36px 48px 0;">
            <!--
              Shield: inline SVG inside a table cell with background-color + border-radius.
              The SVG is absolutely positioned via a wrapping td trick — we just align it
              inside a fixed-size cell so Gmail doesn't need position:absolute.
            -->
            <table cellpadding="0" cellspacing="0" border="0" align="center">
              <tr>
                <td width="72" height="72" align="center" valign="middle"
                    style="width:72px;height:72px;background-color:#deeefb;
                           border-radius:50%;border:1px solid #c3daf7;text-align:center;
                           vertical-align:middle;line-height:72px;">
                  <!-- SVG with explicit width/height so Gmail renders it -->
                  <img src="data:image/svg+xml;base64,"
                       width="34" height="34" alt="Shield verified icon"
                       style="display:inline-block;vertical-align:middle;" />
                </td>
              </tr>
            </table>
          </td>
        </tr>

        <!-- ══ BODY ══ -->
        <tr>
          <td class="body-cell" style="padding:32px 48px 0;">
            <p class="greeting">Hello, <%= userName %>!</p>
            <p class="body-p">
              Welcome to the <strong>DSAGC Learning Management System</strong>. We're glad you're here.
              To get started, please verify your email address by clicking the button below.
            </p>
            <p class="body-p">
              Verifying your email confirms your identity and activates full access to your student
              dashboard, course materials, assignments, and more.
            </p>
          </td>
        </tr>

        <!-- ══ CTA BUTTON ══ -->
        <tr>
          <td class="cta-cell" align="center" style="padding:28px 48px;">
            <table cellpadding="0" cellspacing="0" border="0">
              <tr>
                <td align="center" style="background-color:#1565a8;border-radius:10px;">
                  <a href="<%= link %>" class="cta-btn" target="_blank" rel="noopener noreferrer"
                     style="display:inline-block;background-color:#1565a8;color:#ffffff;
                            text-decoration:none;font-family:Arial,sans-serif;font-size:15px;
                            font-weight:bold;letter-spacing:0.04em;padding:16px 44px;
                            border-radius:10px;">
                    &#10003;&nbsp;&nbsp;Activate My Account
                  </a>
                </td>
              </tr>
            </table>
          </td>
        </tr>

        <!-- ══ EXPIRY NOTICE ══ -->
        <tr>
          <td style="padding:0 48px;">
            <table width="100%" cellpadding="0" cellspacing="0" border="0">
              <tr>
                <td class="expiry-cell"
                    style="padding:14px 20px;background-color:#fff8e1;
                           border-left:4px solid #f59e0b;border-radius:0 8px 8px 0;
                           font-family:Arial,sans-serif;font-size:13px;
                           color:#78520a;line-height:1.6;">
                  &#9203;&nbsp; This verification link will expire in
                  <strong style="color:#b45309;"><%= expiresIn %></strong>.
                  If it expires, you can request a new link from the login page.
                </td>
              </tr>
            </table>
          </td>
        </tr>

        <!-- ══ FALLBACK LINK ══ -->
        <tr>
          <td class="fallback-cell" style="padding:24px 48px 0;">
            <p style="font-family:Arial,sans-serif;font-size:13px;color:#718096;
                      line-height:1.7;margin:0 0 8px 0;">
              If the button above doesn't work, copy and paste this link into your browser:
            </p>
            <table width="100%" cellpadding="0" cellspacing="0" border="0">
              <tr>
                <td style="background-color:#f0f6ff;border:1px solid #c3daf7;
                            border-radius:6px;padding:10px 14px;">
                  <a href="<%= link %>" class="fallback-url" target="_blank" rel="noopener noreferrer"
                     style="word-break:break-all;font-size:12px;color:#1565a8;
                            font-family:'Courier New',monospace;text-decoration:none;">
                    <%= link %>
                  </a>
                </td>
              </tr>
            </table>
          </td>
        </tr>

        <!-- ══ DIVIDER ══ -->
        <tr>
          <td style="padding:28px 48px;">
            <table width="100%" cellpadding="0" cellspacing="0" border="0">
              <tr>
                <td height="1" style="height:1px;background-color:#e8eef6;font-size:0;line-height:0;">&nbsp;</td>
              </tr>
            </table>
          </td>
        </tr>

        <!-- ══ SECURITY NOTE ══ -->
        <tr>
          <td class="security-cell" style="padding:0 48px;">
            <table cellpadding="0" cellspacing="0" border="0" width="100%">
              <tr>
                <td width="24" valign="top" style="vertical-align:top;padding-top:2px;width:24px;">
                  <!-- info icon as base64 SVG -->
                  <img src="data:image/svg+xml;base64,"
                       width="18" height="18" alt="" style="display:block;" />
                </td>
                <td width="12" style="width:12px;">&nbsp;</td>
                <td style="font-family:Arial,sans-serif;font-size:13px;color:#718096;line-height:1.65;">
                  If you did not create an account on <strong>DSAGC LMS</strong>, you can safely ignore
                  this email. No changes will be made to your account. For security concerns, please
                  contact our support team.
                </td>
              </tr>
            </table>
          </td>
        </tr>

        <!-- ══ FOOTER ══ -->
        <tr>
          <td class="footer-cell"
              style="margin-top:32px;background-color:#f7fafd;border-top:1px solid #e2ecf6;
                     padding:28px 48px;text-align:center;">
            <p style="font-family:Georgia,'Times New Roman',serif;font-size:13px;font-weight:600;
                      color:#0b3d6e;margin:0 0 4px 0;">
              Debidwar Sujat Ali Govt. College
            </p>
            <p style="font-family:Arial,sans-serif;font-size:12px;color:#a0aec0;margin:0 0 16px 0;">
              Learning Management System &mdash; Academic Division
            </p>
            <p style="margin:0 0 14px 0;">
              <a href="#" style="font-family:Arial,sans-serif;font-size:12px;color:#1565a8;
                                 text-decoration:none;margin:0 10px;">Help Center</a>
              <a href="#" style="font-family:Arial,sans-serif;font-size:12px;color:#1565a8;
                                 text-decoration:none;margin:0 10px;">Privacy Policy</a>
              <a href="#" style="font-family:Arial,sans-serif;font-size:12px;color:#1565a8;
                                 text-decoration:none;margin:0 10px;">Contact Us</a>
            </p>
            <p style="font-family:Arial,sans-serif;font-size:11px;color:#b0bec9;margin:0;">
              &copy; <%= new Date().getFullYear() %> DSAGC. All rights reserved.<br/>
              This is an automated message. Please do not reply directly to this email.
            </p>
          </td>
        </tr>

      </table><!-- /main card -->
    </td>
  </tr>
</table><!-- /outer wrapper -->

</body>
</html>
